# Copy to .env and adjust. Do NOT commit .env.

# --- Database ---
POSTGRES_DB=ticketing
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=change-me-in-local-env
DB_PORT=5432

# --- Backend ---
BACKEND_PORT=8080
# Base URL of the frontend, used to build email verification / password-reset links
APP_BASE_URL=http://localhost:4200
# HS256 JWT signing secret — MUST be a long random value (>= 32 bytes) in real environments
JWT_SECRET=change-me-to-a-long-random-secret-value-min-32-bytes
# JWT / session lifetime in seconds (default 7 days)
JWT_TTL_SECONDS=604800

# --- SMTP (email verification) ---
# Defaults below point at the local Mailpit container (see docker-compose).
# For a real relay set e.g. SMTP_HOST=relay1.dataart.com / SMTP_PORT=25 (and SMTP_AUTH/STARTTLS as needed).
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
MAIL_FROM=no-reply@dataart.com

# --- Frontend ---
FRONTEND_PORT=4200

# --- Dev tooling ---
# Mailpit (local email sink)
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
# pgAdmin (database web UI)
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@dataart.com
PGADMIN_DEFAULT_PASSWORD=admin
